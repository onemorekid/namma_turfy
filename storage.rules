rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function to check if the user is the owner of the venue
    function isVenueOwner(venueId) {
      return request.auth != null && 
        firestore.get(/databases/(default)/documents/venues/$(venueId)).data.ownerId == request.auth.uid;
    }

    // Helper function to check if user owns the venue that the zone belongs to
    function isZoneOwner(zoneId) {
      let zone = firestore.get(/databases/(default)/documents/zones/$(zoneId)).data;
      return request.auth != null && 
        firestore.get(/databases/(default)/documents/venues/$(zone.venueId)).data.ownerId == request.auth.uid;
    }

    // Venue images — public read, owner-only write
    match /venues/{venueId}/{fileName} {
      allow read: if true;
      // Allow write if venue doesn't exist yet (creation) OR if requester is owner
      allow write: if request.auth != null && (
        !firestore.exists(/databases/(default)/documents/venues/$(venueId)) || 
        isVenueOwner(venueId)
      );
    }

    // Zone images — public read, owner-only write
    match /zones/{zoneId}/{fileName} {
      allow read: if true;
      // Allow write if zone doesn't exist yet (creation) OR if requester is owner
      allow write: if request.auth != null && (
        !firestore.exists(/databases/(default)/documents/zones/$(zoneId)) || 
        isZoneOwner(zoneId)
      );
    }
  }
}
